server:
  host: 0.0.0.0
  port: 9500

audio:
  radio_pan: 0.0  # -1.0 = left ear, 0.0 = both ears, 1.0 = right ear

# Optional mission/session context — added to all LLM prompts.
# Describe the scenario so NPCs and intent parsing have context.
# prompt: "NATO forces patrol Malden island. CSAT insurgents operate in the south. Our squad is recon team Alpha."
prompt: ""

stt:
  system: whisper  # whisper | deepgram | windows
  whisper:
    model_path: ggml-base.en.bin
  deepgram:
    api_key: YOUR_DEEPGRAM_API_KEY
    model: nova-2
    language: ru
    encoding: linear16
    sample_rate: 16000
  windows:
    language: en-US  # BCP-47 locale: en-US, ru-RU, uk-UA, etc.

tts:
  system: piper  # piper | elevenlabs
  piper:
    url: http://localhost:5000
  elevenlabs:
    api_key: YOUR_ELEVENLABS_API_KEY
    model_id: eleven_multilingual_v2
    stability: 0.75
    similarity_boost: 0.75
    style: 0.2
    use_speaker_boost: false
    voices:
      default: YOUR_DEFAULT_VOICE_ID
      blufor: YOUR_BLUFOR_VOICE_ID
      opfor: YOUR_OPFOR_VOICE_ID
      indfor: YOUR_INDFOR_VOICE_ID
      # per unit name:
      # Miller: YOUR_MILLER_VOICE_ID

llm:
  intent:
    system: gemini  # gemini | claude
    gemini:
      api_key: YOUR_GEMINI_API_KEY
      model: gemini-2.0-flash-lite
      thinking_budget: 0
    claude:
      api_key: YOUR_CLAUDE_API_KEY
      model: claude-sonnet-4-20250514
  dialogue:
    system: claude  # gemini | claude
    gemini:
      api_key: YOUR_GEMINI_API_KEY
      model: gemini-2.0-flash-lite
      thinking_budget: 0
    claude:
      api_key: YOUR_CLAUDE_API_KEY
      model: claude-sonnet-4-20250514
